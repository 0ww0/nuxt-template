{
    "extends": "../tsconfig.json",
    "compilerOptions": {
        "module": "ESNext",
        "moduleResolution": "Bundler",
        "paths": {
            "@/*": ["../app/*"],
            "@components/*": ["../app/components/*"],
            "@composables/*": ["../app/composables/*"],
            "@utils/*": ["../app/utils/*"],
            "@shared/*": ["../shared/*"],
            "@server/*": ["../server/*"]
        }
    },
    "include": [
        "**/*.ts"
    ]
}