NUXT_PUBLIC_APP_URL=""
NUXT_SESSION_SECRET=your-secret-here
NUXT_WEBHOOK_SECRET=""
DATABASE_URL=postgresql://nuxt:nuxt@localhost:5432/nuxtdb

# Mail transport — used by server/utils/mailer.ts in development.
# Point at Mailpit (docker compose -f docker-compose.dev.yml up -d).
# In production, replace with your SMTP provider or remove and wire
# an API-based transport (Resend, Postmark, SES) in mailer.ts instead.
SMTP_HOST=localhost
SMTP_PORT=1025
